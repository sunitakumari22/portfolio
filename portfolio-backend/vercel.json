{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/portfolio/Messages",
      "dest": "/index.js"
    },
    {
      "src": "/portfolio/Messages/(.*)",
      "dest": "/index.js"
    },
    {
      "src": "/business",
      "dest": "/index.js"
    },
    {
      "src": "/business/(.*)",
      "dest": "/index.js"
    }
  ]
}